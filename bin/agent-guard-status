#!/usr/bin/env bash
#
# Agent Guard Status — quick shortcut to view all sessions/worktrees.
#
# Usage:
#   ./agent-guard-status
#   source agent-guard-status
#   bash agent-guard-status
#
# Equivalent to:
#   source agent-guard init --status

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Resolve repository root from the current directory or the script location.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${REPO_ROOT}" ]]; then
    REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
fi

PACKAGE_ROOT="$(bash "${SCRIPT_DIR}/agent-guard-config" get paths.package_root 'packages/agent-guard-core' 2>/dev/null || echo 'packages/agent-guard-core')"
INIT_SCRIPT_NAME="$(bash "${SCRIPT_DIR}/agent-guard-config" get paths.init_script '.agent-guard-init' 2>/dev/null || echo '.agent-guard-init')"
INIT_SCRIPT="${REPO_ROOT}/${INIT_SCRIPT_NAME}"

if [[ ! -f "${INIT_SCRIPT}" ]]; then
    echo "❌ Init script not found at ${INIT_SCRIPT}" >&2
    return 1 2>/dev/null || exit 1
fi

cd "${REPO_ROOT}"
source "${INIT_SCRIPT}" --status
